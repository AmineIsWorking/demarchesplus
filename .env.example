# Anthropic API Key — récupérez-la sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modèle utilisé (claude-sonnet-4-5 par défaut, équilibre coût/qualité)
# Alternatives : claude-opus-4-7 (meilleure qualité, plus cher) | claude-haiku-4-5 (plus rapide, moins cher)
ANTHROPIC_MODEL=claude-sonnet-4-5
